---
interface Props {
  title?: string;
}
const { title = 'Apuestas Dashboard' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=block"
      rel="stylesheet"
    />
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  </head>
  <body>
    <!-- Preloader -->
    <div id="preloader">
      <div class="pre-brand">KNG DAN</div>
      <div class="pre-sub">Apuestas Analytics Platform</div>
      <div class="pre-bar"><div class="pre-bar-fill"></div></div>
      <div class="pre-ver">v2.4.0</div>
    </div>
    <style is:inline>
      #preloader{position:fixed;inset:0;z-index:9999;background:#07090d;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0;transition:opacity .6s cubic-bezier(.4,0,.2,1),visibility .6s}
      #preloader.hidden{opacity:0;visibility:hidden;pointer-events:none}
      .pre-brand{font-family:'Space Grotesk','SF Pro Display','Segoe UI',system-ui,sans-serif;font-size:28px;font-weight:700;letter-spacing:8px;color:#fff;margin-bottom:8px;animation:preReveal .5s ease both}
      .pre-sub{font-family:'Inter','SF Pro Text','Segoe UI',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:3px;color:rgba(255,255,255,0.18);text-transform:uppercase;margin-bottom:40px;animation:preReveal .5s ease both .15s}
      .pre-bar{width:160px;height:2px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden;margin-bottom:16px;animation:preReveal .4s ease both .25s}
      .pre-bar-fill{width:0;height:100%;background:linear-gradient(90deg,rgba(0,229,255,0.8),rgba(0,245,139,0.7));border-radius:2px;animation:barFill 1.2s cubic-bezier(.4,0,.2,1) .3s forwards}
      @keyframes barFill{to{width:100%}}
      .pre-ver{font-family:'Space Grotesk','SF Mono',monospace;font-size:9px;font-weight:500;color:rgba(255,255,255,0.1);letter-spacing:2px;animation:preReveal .4s ease both .35s}
      @keyframes preReveal{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
      .page-content{opacity:0;transition:opacity .4s ease}.page-content.loaded{opacity:1}
    </style>
    <div class="page-content" id="pageContent">
      <slot />
    </div>
    <script is:inline>
      window.addEventListener('load',function(){
        var p=document.getElementById('preloader'),c=document.getElementById('pageContent');
        setTimeout(function(){if(p)p.classList.add('hidden');if(c)c.classList.add('loaded')},400);
        setTimeout(function(){if(p)p.remove()},1000);
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #07090d;
    --c-green: #00f58b;
    --c-red: #ff3b5e;
    --c-dim: #ff8f8f;
    --panel-w: 340px;
    --glass-opacity: 0.18;
    --blur: 22px;
    --glow-str: 0.18;
    --card-radius: 22px;
    --font: 'Inter', -apple-system, sans-serif;
    --mono: 'Space Grotesk', monospace;
  }

  html, body {
    width: 100%;
    min-height: 100vh;
    background: var(--bg);
    color: #fff;
    font-family: var(--font);
    overflow-x: hidden;
  }
</style>
