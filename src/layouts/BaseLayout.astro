---
interface Props {
  title?: string;
}
const { title = 'Trading Dashboard' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #07090d;
    --c-green: #00f58b;
    --c-red: #ff3b5e;
    --c-dim: #ff8f8f;
    --panel-w: 340px;
    --glass-opacity: 0.18;
    --blur: 22px;
    --glow-str: 0.18;
    --card-radius: 22px;
    --font: 'Inter', -apple-system, sans-serif;
    --mono: 'Space Grotesk', monospace;
  }

  html, body {
    width: 100%;
    min-height: 100vh;
    background: var(--bg);
    color: #fff;
    font-family: var(--font);
    overflow-x: hidden;
  }
</style>
