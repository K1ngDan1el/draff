---
---

<canvas id="bg-canvas"></canvas>

<style>
  #bg-canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
</style>

<script>
  const cvs = document.getElementById('bg-canvas') as HTMLCanvasElement;
  const ctx = cvs.getContext('2d')!;

  export const bgCfg = { speed: 1, intensity: 0.55, scale: 280, theme: 'dark' };

  export const themes: Record<string, { bg: string; colors: string[] }> = {
    dark:   { bg: '#07090d', colors: ['#001a40','#0d001a','#001410','#0d0d00','#07090d'] },
    aurora: { bg: '#030810', colors: ['#003355','#00442a','#1a0044','#002233','#000d22'] },
    ocean:  { bg: '#020810', colors: ['#001633','#002244','#003333','#001122','#020810'] },
    ember:  { bg: '#0d0500', colors: ['#2a0800','#1a0a00','#2a0000','#0f0a00','#0d0500'] },
    void:   { bg: '#050005', colors: ['#0a0015','#00050a','#100008','#05000f','#050005'] },
  };

  function resizeBg() {
    cvs.width = window.innerWidth;
    cvs.height = window.innerHeight;
  }
  resizeBg();
  window.addEventListener('resize', resizeBg);

  function hash(x: number, y: number) {
    const n = Math.sin(x * 127.1 + y * 311.7) * 43758.5453;
    return n - Math.floor(n);
  }
  function smoothstep(t: number) { return t * t * (3 - 2 * t); }
  function vnoise(x: number, y: number) {
    const ix = Math.floor(x), iy = Math.floor(y);
    const fx = x - ix, fy = y - iy;
    const a = hash(ix, iy), b = hash(ix+1, iy), c = hash(ix, iy+1), d = hash(ix+1, iy+1);
    const ux = smoothstep(fx), uy = smoothstep(fy);
    return a + (b-a)*ux + (c-a)*uy + (a-b-c+d)*ux*uy;
  }
  function fbm(x: number, y: number, oct: number) {
    let v = 0, amp = 0.5, freq = 1, max = 0;
    for (let i = 0; i < oct; i++) {
      v += amp * vnoise(x * freq, y * freq);
      max += amp; amp *= 0.5; freq *= 2;
    }
    return v / max;
  }

  let t = 0;
  function drawBg() {
    const W = cvs.width, H = cvs.height;
    const theme = themes[bgCfg.theme];
    const sc = bgCfg.scale, inten = bgCfg.intensity;

    ctx.fillStyle = theme.bg;
    ctx.fillRect(0, 0, W, H);

    const orbs = [
      { x: 0.3  + 0.2  * Math.sin(t * 0.4),  y: 0.2 + 0.15 * Math.cos(t * 0.5),  r: 0.4,  ci: 0 },
      { x: 0.7  + 0.15 * Math.cos(t * 0.3),  y: 0.6 + 0.2  * Math.sin(t * 0.35), r: 0.35, ci: 1 },
      { x: 0.5  + 0.25 * Math.sin(t * 0.55), y: 0.8 + 0.1  * Math.cos(t * 0.7),  r: 0.3,  ci: 2 },
      { x: 0.1  + 0.1  * Math.cos(t * 0.45), y: 0.5 + 0.25 * Math.sin(t * 0.4),  r: 0.25, ci: 3 },
      { x: 0.85 + 0.1  * Math.sin(t * 0.6),  y: 0.2 + 0.2  * Math.cos(t * 0.35), r: 0.28, ci: 4 },
    ];

    for (const o of orbs) {
      const gx = o.x * W, gy = o.y * H;
      const gr = Math.min(W, H) * o.r * inten * 1.4;
      const g = ctx.createRadialGradient(gx, gy, 0, gx, gy, gr);
      const col = theme.colors[o.ci % theme.colors.length];
      g.addColorStop(0, col + 'cc');
      g.addColorStop(0.5, col + '55');
      g.addColorStop(1, col + '00');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, W, H);
    }

    const step = 6;
    for (let y = 0; y < H; y += step) {
      for (let x = 0; x < W; x += step) {
        const n = fbm(x / sc + t * 0.08, y / sc + t * 0.06, 4);
        const a = (n - 0.45) * inten * 0.25;
        if (a > 0.008) {
          ctx.fillStyle = `rgba(255,255,255,${Math.min(a, 0.035)})`;
          ctx.fillRect(x, y, step, step);
        }
      }
    }
    for (let y = 0; y < H; y += 2) {
      ctx.fillStyle = 'rgba(0,0,0,0.04)';
      ctx.fillRect(0, y, W, 1);
    }

    t += 0.004 * bgCfg.speed;
    requestAnimationFrame(drawBg);
  }

  drawBg();

  // Expose bgCfg and themes globally so Editor can mutate them
  (window as any).__bgCfg = bgCfg;
  (window as any).__bgThemes = themes;
</script>
