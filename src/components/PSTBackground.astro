---
---

<canvas id="pst-bg-canvas"></canvas>

<style>
  #pst-bg-canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.8;
  }
</style>

<script>
  const cvs = document.getElementById('pst-bg-canvas') as HTMLCanvasElement;
  const ctx = cvs.getContext('2d')!;

  function resizeBg() {
    cvs.width = window.innerWidth;
    cvs.height = window.innerHeight;
  }
  resizeBg();
  window.addEventListener('resize', resizeBg);

  let t = 0;
  let lastFrame = 0;

  function drawWave(
    yBase: number, color: string, fillColor: string,
    speed: number, amplitude: number, freq: number, phase: number,
    W: number, H: number
  ) {
    ctx.beginPath();
    ctx.moveTo(0, H);

    // Smooth flowing curves — wide sine waves, not sharp zigzags
    for (let x = 0; x <= W; x += 3) {
      const y = yBase
        + Math.sin(x * freq + t * speed + phase) * amplitude
        + Math.sin(x * freq * 0.4 + t * speed * 0.6 + 2) * (amplitude * 0.6)
        + Math.sin(x * freq * 0.15 - t * speed * 0.3 + 4) * (amplitude * 0.3);
      ctx.lineTo(x, y);
    }

    // Close to bottom for fill
    ctx.lineTo(W, H);
    ctx.closePath();

    // Gradient fill under curve
    const grad = ctx.createLinearGradient(0, yBase - amplitude, 0, H);
    grad.addColorStop(0, fillColor);
    grad.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = grad;
    ctx.fill();

    // Stroke the wave line
    ctx.beginPath();
    for (let x = 0; x <= W; x += 3) {
      const y = yBase
        + Math.sin(x * freq + t * speed + phase) * amplitude
        + Math.sin(x * freq * 0.4 + t * speed * 0.6 + 2) * (amplitude * 0.6)
        + Math.sin(x * freq * 0.15 - t * speed * 0.3 + 4) * (amplitude * 0.3);
      if (x === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.5;
    ctx.stroke();
  }

  function draw(now: number) {
    requestAnimationFrame(draw);
    if (document.hidden) return;
    if (now - lastFrame < 33) return;
    lastFrame = now;

    const W = cvs.width, H = cvs.height;
    ctx.clearRect(0, 0, W, H);

    // 4 layered flowing waves — slow, wide, organic
    drawWave(H * 0.45, 'rgba(0,229,255,0.25)', 'rgba(0,229,255,0.04)',
      0.4, H * 0.06, 0.0012, 0, W, H);

    drawWave(H * 0.55, 'rgba(0,245,139,0.3)', 'rgba(0,245,139,0.05)',
      0.55, H * 0.07, 0.001, 2, W, H);

    drawWave(H * 0.65, 'rgba(168,85,247,0.2)', 'rgba(168,85,247,0.03)',
      0.35, H * 0.05, 0.0015, 4, W, H);

    drawWave(H * 0.75, 'rgba(255,59,94,0.15)', 'rgba(255,59,94,0.025)',
      0.3, H * 0.04, 0.0018, 6, W, H);

    t += 0.015;
  }

  requestAnimationFrame(draw);
</script>
