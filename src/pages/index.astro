---
import '../styles/dashboard-pst.css';
import PSTBackground from '../components/PSTBackground.astro';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Dashboard PST — Análisis de pérdidas y ganancias con visualización interactiva">
  <title>Dashboard PST</title>
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=block" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body>

  <!-- ═══ Preloader ═══ -->
  <div id="preloader">
    <div class="pre-brand">KNG DAN</div>
    <div class="pre-sub">Apuestas Analytics Platform</div>
    <div class="pre-bar"><div class="pre-bar-fill"></div></div>
    <div class="pre-ver">v2.4.0</div>
  </div>
  <style is:inline>
    #preloader{position:fixed;inset:0;z-index:9999;background:#07090d;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0;transition:opacity .6s cubic-bezier(.4,0,.2,1),visibility .6s}
    #preloader.hidden{opacity:0;visibility:hidden;pointer-events:none}
    .pre-brand{font-family:'Space Grotesk','Segoe UI',system-ui,sans-serif;font-size:28px;font-weight:700;letter-spacing:8px;color:#fff;margin-bottom:8px;animation:preReveal .5s ease both}
    .pre-sub{font-family:'Inter','Segoe UI',system-ui,sans-serif;font-size:10px;font-weight:500;letter-spacing:3px;color:rgba(255,255,255,0.18);text-transform:uppercase;margin-bottom:40px;animation:preReveal .5s ease both .15s}
    .pre-bar{width:160px;height:2px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden;margin-bottom:16px;animation:preReveal .4s ease both .25s}
    .pre-bar-fill{width:0;height:100%;background:linear-gradient(90deg,rgba(0,229,255,0.8),rgba(0,245,139,0.7));border-radius:2px;animation:barFill 1.2s cubic-bezier(.4,0,.2,1) .3s forwards}
    @keyframes barFill{to{width:100%}}
    .pre-ver{font-family:'Space Grotesk',monospace;font-size:9px;font-weight:500;color:rgba(255,255,255,0.1);letter-spacing:2px;animation:preReveal .4s ease both .35s}
    @keyframes preReveal{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
    .page-content{opacity:0;transition:opacity .4s ease}.page-content.loaded{opacity:1}
  </style>

  <div class="page-content" id="pageContent">

  <PSTBackground />

  <header>
    <h1>Dashboard <span>PST</span></h1>
    <p id="headerSub">Pérdidas y Ganancias · sube un archivo para comenzar</p>
    <div style="display:flex; justify-content:center; gap: 12px; align-items:center;">
      <button id="btnLoadCloud" class="preset-btn" style="margin-top: 16px; padding: 10px 20px; font-size: 13px; background: rgba(168,85,247,0.15); border-color: rgba(168,85,247,0.3); color: #a855f7; box-shadow: 0 0 20px rgba(168,85,247,0.1);">
        ⬇️ Cargar de la Nube
      </button>
      <button id="btnSaveCloud" class="preset-btn" style="display:none; margin-top: 16px; padding: 10px 20px; font-size: 13px; background: rgba(0,229,255,0.15); border-color: rgba(0,229,255,0.3); color: #00e5ff; box-shadow: 0 0 20px rgba(0,229,255,0.1);">
        ☁️ Guardar en la Nube
      </button>
    </div>
  </header>

  <div class="wrap">

    <!-- Upload Zone -->
    <div class="upload-zone" id="uploadZone">
      <input type="file" id="fileInput" accept=".xlsx,.xls,.csv">
      <div class="upload-icon">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(0,229,255,0.6)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="17 8 12 3 7 8"/>
          <line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
      </div>
      <div class="upload-title">Sube tu archivo Excel o CSV</div>
      <div class="upload-sub">Arrastra aquí o haz clic · columnas: PÉRDIDAS y GANANCIAS</div>
      <div class="upload-status" id="uploadStatus"></div>
    </div>

    <!-- KPI Cards -->
    <div class="kpis">
      <div class="card green">
        <div class="card-highlight"></div>
        <div class="card-glow-effect"></div>
        <div class="card-label">Ganancias</div>
        <div class="card-value" id="kpiGanancias">—</div>
        <div class="card-sub" id="kpiGananciasOps">— operaciones</div>
        <div class="card-icon">↑</div>
      </div>
      <div class="card red">
        <div class="card-highlight"></div>
        <div class="card-glow-effect"></div>
        <div class="card-label">Pérdidas</div>
        <div class="card-value" id="kpiPerdidas">—</div>
        <div class="card-sub" id="kpiPerdidasOps">— operaciones</div>
        <div class="card-icon">↓</div>
      </div>
      <div class="card negative" id="kpiNetCard">
        <div class="card-highlight"></div>
        <div class="card-glow-effect"></div>
        <div class="card-label">Profit Neto</div>
        <div class="card-value" id="kpiNeto">—</div>
        <div class="card-sub" id="kpiNetoSub">—</div>
        <div class="card-icon">Σ</div>
      </div>
    </div>

    <!-- Charts Panel -->
    <div class="panel">
      <div class="chart-tabs">
        <button class="chart-tab active" data-tab="linea">Evolución acumulada</button>
        <button class="chart-tab" data-tab="barras">Distribución por rango</button>
        <button class="chart-tab" data-tab="ambas">Por operación</button>
      </div>
      <div class="chart-panel active" id="tab-linea"><canvas id="chartLinea"></canvas></div>
      <div class="chart-panel" id="tab-barras"><canvas id="chartBarras"></canvas></div>
      <div class="chart-panel" id="tab-ambas"><canvas id="chartAmbas"></canvas></div>
      <div class="stats-row">
        <div class="stat">
          <div class="stat-label">Máx. ganancia</div>
          <div class="stat-val val-green" id="statMaxG">—</div>
        </div>
        <div class="stat">
          <div class="stat-label">Prom. ganancia</div>
          <div class="stat-val val-green" id="statPromG">—</div>
        </div>
        <div class="stat">
          <div class="stat-label">Máx. pérdida</div>
          <div class="stat-val val-red" id="statMaxP">—</div>
        </div>
        <div class="stat">
          <div class="stat-label">Prom. pérdida</div>
          <div class="stat-val val-red" id="statPromP">—</div>
        </div>
      </div>
    </div>

    <!-- Data Table Panel -->
    <div class="panel">
      <div class="panel-header">
        <span class="panel-title" id="tableTitle">Datos</span>
      </div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>#</th><th>PÉRDIDAS</th><th>GANANCIAS</th></tr></thead>
          <tbody id="tableBody">
            <tr><td colspan="3" style="color:var(--muted);text-align:center;padding:40px;font-size:13px;">Sube un archivo Excel para ver los datos aquí</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  </div> <!-- /page-content -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

  <script src="../scripts/dashboard-pst.ts"></script>

  <a href="/trading" class="insta"><span>FRONT</span></a>

  <!-- Preloader dismiss -->
  <script is:inline>
    window.addEventListener('load', function() {
      var pre = document.getElementById('preloader');
      var content = document.getElementById('pageContent');
      setTimeout(function() {
        if (pre) pre.classList.add('hidden');
        if (content) content.classList.add('loaded');
      }, 400);
      setTimeout(function() { if (pre) pre.remove(); }, 1000);
    });
  </script>

  <script>
    // ═══ Interactive Animations ═══
    let tiltEnabled = true;
    (window as any).__disableTilt = () => { tiltEnabled = false; };
    (window as any).__enableTilt = () => { tiltEnabled = true; };

    document.querySelectorAll('.card').forEach((card) => {
      const el = card as HTMLElement;
      el.addEventListener('mousemove', (e) => {
        if (!tiltEnabled) return;
        const rect = el.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        el.style.transform = `perspective(800px) rotateY(${x * 12}deg) rotateX(${-y * 12}deg) translateY(-8px) scale(1.02)`;
        const glow = el.querySelector('.card-glow-effect') as HTMLElement;
        if (glow) glow.style.background = `radial-gradient(circle at ${50+x*60}% ${50+y*60}%, rgba(var(--card-color),0.25), transparent 65%)`;
      });
      el.addEventListener('mouseleave', () => {
        if (!tiltEnabled) return;
        el.style.transform = '';
        const glow = el.querySelector('.card-glow-effect') as HTMLElement;
        if (glow) glow.style.background = '';
      });
    });

    // Click ripple
    document.querySelectorAll('.chart-tab, .insta, .upload-zone').forEach((el) => {
      el.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const rect = target.getBoundingClientRect();
        const ripple = document.createElement('span');
        const size = Math.max(rect.width, rect.height) * 2;
        ripple.style.cssText = `position:absolute;border-radius:50%;pointer-events:none;width:${size}px;height:${size}px;left:${(e as MouseEvent).clientX-rect.left-size/2}px;top:${(e as MouseEvent).clientY-rect.top-size/2}px;background:rgba(255,255,255,0.12);animation:rippleOut 0.6s ease-out forwards;`;
        target.style.position = 'relative';
        target.appendChild(ripple);
        setTimeout(() => ripple.remove(), 650);
      });
    });

    // Chart tab transitions
    document.querySelectorAll('.chart-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const panel = document.getElementById('tab-' + (tab as HTMLElement).dataset.tab);
        if (panel && (window as any).gsap) {
          (window as any).gsap.fromTo(panel, {opacity:0,y:12,scale:0.98}, {opacity:1,y:0,scale:1,duration:0.35,ease:'power2.out'});
        }
      });
    });

    // Magnetic FRONT button
    const instaBtn = document.querySelector('.insta') as HTMLElement;
    if (instaBtn) {
      instaBtn.addEventListener('mousemove', (e) => {
        const rect = instaBtn.getBoundingClientRect();
        instaBtn.style.transform = `translate(${(e.clientX-rect.left-rect.width/2)*0.15}px, ${(e.clientY-rect.top-rect.height/2)*0.15-4}px) scale(1.05)`;
      });
      instaBtn.addEventListener('mouseleave', () => { instaBtn.style.transform = ''; });
    }
  </script>

</body>
</html>