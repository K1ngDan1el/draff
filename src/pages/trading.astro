---
import '../styles/trading.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import BackgroundCanvas from '../components/BackgroundCanvas.astro';
import TradingCard from '../components/TradingCard.astro';
import Editor from '../components/Editor.astro';
---

<BaseLayout title="Apuestas Dashboard">

  <!-- SVG global filters -->
  <svg style="position:absolute;width:0;height:0" aria-hidden="true">
    <defs>
      <filter id="glow-g" x="-30%" y="-30%" width="160%" height="160%">
        <feGaussianBlur stdDeviation="2.5" result="b"/>
        <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <filter id="glow-r" x="-30%" y="-30%" width="160%" height="160%">
        <feGaussianBlur stdDeviation="2.5" result="b"/>
        <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <filter id="glow-dim" x="-30%" y="-30%" width="160%" height="160%">
        <feGaussianBlur stdDeviation="2.5" result="b"/>
        <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
    </defs>
  </svg>

  <BackgroundCanvas />

  <div class="scene">
    <div class="header">
      <h1 id="dashboard-title">Apuestas Dashboard</h1>
      <p id="dashboard-sub">ANÁLISIS DE RENDIMIENTO · GANANCIAS & PÉRDIDAS</p>
    </div>

    <div class="dashboard" id="dashboard">

      <TradingCard
        id="card-0"
        idx={0}
        colorClass="card-green"
        iconStroke="rgb(0,245,139)"
        iconPath={`<path d="M22 7L13.5 15.5L8.5 10.5L2 17" stroke-linecap="round" stroke-linejoin="round"/>
                   <polyline points="16 7 22 7 22 13" stroke-linecap="round" stroke-linejoin="round"/>`}
        label="GANANCIAS"
        amount="$41,225.00"
        badge="41 operaciones"
        gradientId="fade-g"
        chartFill="M0 50 L20 48 L40 50 L60 45 L80 48 L100 35 L120 45 L140 38 L160 42 L180 35 L200 38 L220 35 L240 25 L260 28 L280 15 L300 5 L300 62 L0 62 Z"
        chartPath="M0 50 L20 48 L40 50 L60 45 L80 48 L100 35 L120 45 L140 38 L160 42 L180 35 L200 38 L220 35 L240 25 L260 28 L280 15 L300 5"
        filterId="glow-g"
      />

      <TradingCard
        id="card-1"
        idx={1}
        colorClass="card-red"
        iconStroke="rgb(255,59,94)"
        iconPath={`<path d="M22 17L13.5 8.5L8.5 13.5L2 7" stroke-linecap="round" stroke-linejoin="round"/>
                   <polyline points="16 17 22 17 22 11" stroke-linecap="round" stroke-linejoin="round"/>`}
        label="PÉRDIDAS"
        amount="$60,273.00"
        badge="599 operaciones"
        gradientId="fade-r"
        chartFill="M0 45 L20 45 L40 48 L60 47 L80 47 L100 48 L120 40 L140 45 L160 35 L180 38 L200 28 L220 32 L240 5 L260 20 L280 35 L300 45 L300 62 L0 62 Z"
        chartPath="M0 45 L20 45 L40 48 L60 47 L80 47 L100 48 L120 40 L140 45 L160 35 L180 38 L200 28 L220 32 L240 5 L260 20 L280 35 L300 45"
        filterId="glow-r"
      />

      <TradingCard
        id="card-2"
        idx={2}
        colorClass="card-dark"
        iconStroke="rgb(255,143,143)"
        iconPath={`<path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"/>
                   <path d="M4 6v12a2 2 0 0 0 2 2h14v-4"/>
                   <path d="M18 12a2 2 0 0 0-2 2 2 2 0 0 0 2 2h2v-4h-2z"/>`}
        label="PROFIT NETO"
        amount="-$19,048.00"
        badge="negativo"
        chartPath="M0 40 L40 40 L80 38 L120 42 L160 45 L200 48 L240 50 L300 55"
        filterId="glow-dim"
        showSigma={true}
      />

    </div>
  </div>

  <Editor />

</BaseLayout>

<a href="/" class="home" onclick="sessionStorage.removeItem('tradingData')">HOME</a>

<script>
  // ═══ Trading Page Animations ═══
  const gsap = (window as any).gsap;

  if (gsap) {
    // Cards staggered entrance
    const cards = document.querySelectorAll('.card');
    gsap.fromTo(cards,
      { opacity: 0, y: 40, scale: 0.95 },
      { opacity: 1, y: 0, scale: 1,
        stagger: 0.15, duration: 0.7,
        ease: 'power3.out', delay: 0.3 }
    );

    // Header entrance
    const header = document.querySelector('.header');
    if (header) {
      gsap.fromTo(header,
        { opacity: 0, y: -20 },
        { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', delay: 0.1 }
      );
    }

    // Home button
    const homeBtn = document.querySelector('.home');
    if (homeBtn) {
      gsap.fromTo(homeBtn,
        { opacity: 0, x: -15 },
        { opacity: 1, x: 0, duration: 0.5, ease: 'power2.out', delay: 0.6 }
      );
    }

    // Card amounts fade in
    document.querySelectorAll('.card-amount').forEach((el, i) => {
      gsap.fromTo(el,
        { opacity: 0, y: 10 },
        { opacity: 1, y: 0, duration: 0.5, delay: 0.5 + i * 0.15, ease: 'power2.out' }
      );
    });
  }

  // 3D Tilt on Trading Cards
  document.querySelectorAll('.card').forEach((card) => {
    const el = card as HTMLElement;
    el.addEventListener('mousemove', (e) => {
      const rect = el.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      el.style.transform = `perspective(800px) rotateY(${x * 14}deg) rotateX(${-y * 14}deg) translateY(-8px) scale(1.02)`;
      const glow = el.querySelector('.card-glow') as HTMLElement;
      if (glow) {
        glow.style.background = `radial-gradient(circle at ${50 + x * 60}% ${50 + y * 60}%, rgba(var(--card-color), 0.3), transparent 65%)`;
      }
    });
    el.addEventListener('mouseleave', () => {
      el.style.transform = '';
      const glow = el.querySelector('.card-glow') as HTMLElement;
      if (glow) glow.style.background = '';
    });
  });

  // Magnetic HOME button
  const homeEl = document.querySelector('.home') as HTMLElement;
  if (homeEl) {
    homeEl.addEventListener('mousemove', (e) => {
      const rect = homeEl.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      homeEl.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px) scale(1.1)`;
    });
    homeEl.addEventListener('mouseleave', () => {
      homeEl.style.transform = '';
    });
  }
</script>

